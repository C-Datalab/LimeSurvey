# -------------------------------------------------------
# LimeSurvey Self-Hosted Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# Application URL (no trailing slash)
# Local development:  http://localhost:9514
# Production server:  https://forms.yourcompany.com
BASE_URL=http://localhost:9514

# Port LimeSurvey will be available on (host machine)
APP_PORT=9514

# -------------------------------------------------------
# Admin account
# Created automatically on first boot.
# Cannot be changed via env variables after initialisation —
# use the admin panel to update credentials afterwards.
# -------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=changeme_strong_password
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@yourcompany.com

# -------------------------------------------------------
# Database passwords (use strong random strings in production)
# Generate with: openssl rand -hex 32
# -------------------------------------------------------
DB_PASSWORD=changeme_db_password
DB_ROOT_PASSWORD=changeme_root_password
