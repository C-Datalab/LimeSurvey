# -------------------------------------------------------
# LimeSurvey Self-Hosted Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# Application URL (no trailing slash)
# Local development:  http://localhost:9514
# Production server:  https://forms.yourcompany.com
BASE_URL=http://localhost:9514

# Port LimeSurvey will be available on (host machine)
APP_PORT=9514

# -------------------------------------------------------
# Admin account
# Created automatically on first boot.
# Cannot be changed via env variables after initialisation —
# use the admin panel to update credentials afterwards.
# -------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=changeme_strong_password
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@yourcompany.com

# -------------------------------------------------------
# Database passwords (use strong random strings in production)
# Generate with: openssl rand -hex 32
# -------------------------------------------------------
DB_PASSWORD=changeme_db_password
DB_ROOT_PASSWORD=changeme_root_password

# -------------------------------------------------------
# SMTP — AWS SES (Tokyo region)
# SMTP credentials are generated in AWS Console:
#   SES → SMTP Settings → Create SMTP Credentials
# The SMTP username/password are NOT your AWS access keys —
# they are separate credentials generated specifically for SMTP.
# -------------------------------------------------------
SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your_ses_smtp_username
SMTP_PASSWORD=your_ses_smtp_password
SMTP_FROM=noreply@yourcompany.com
SMTP_SSL=tls
